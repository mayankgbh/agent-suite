// Agent Suite - Prisma schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OnboardingStatus {
  pending
  in_progress
  complete
}

enum UserRole {
  owner
  admin
  member
  viewer
}

enum AgentType {
  marketing
  sales
  engineering
  finance
}

enum AgentStatus {
  onboarding
  active
  paused
  archived
}

enum OKRStatus {
  proposed
  negotiating
  accepted
  in_progress
  completed
  failed
}

enum TimeHorizon {
  weekly
  monthly
  quarterly
}

enum TaskStatus {
  planned
  in_progress
  blocked
  completed
  failed
}

enum TaskPriority {
  critical
  high
  medium
  low
}

enum MessageRole {
  agent
  user
  system
}

enum MessageType {
  onboarding_question
  okr_negotiation
  status_update
  daily_report
  question
  answer
  deliverable
}

enum ToolType {
  slack
  github
  google_workspace
  hubspot
  stripe
  web_scraper
  email_sender
  seo_analyzer
  content_generator
  social_poster
  analytics_reader
  google_sheets
  slack_notifier
}

enum ToolIntegrationStatus {
  connected
  disconnected
  error
}

model Organization {
  id                 String             @id @default(uuid())
  clerk_org_id       String?            @unique // Clerk organization id (org_xxx)
  name               String
  slug               String             @unique
  website_url        String?
  industry           String?
  company_size       String?
  icp_description    String?            @db.Text
  business_context   Json?              // scraped + user-provided context
  onboarding_status  OnboardingStatus   @default(pending)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  users              User[]
  agents             Agent[]
  okrs               OKR[]
  tool_integrations  ToolIntegration[]
  agent_messages     AgentMessage[]
  daily_reports      DailyReport[]
  events             Event[]
  agent_files        AgentFile[]
  coordination_messages CoordinationMessage[]
}

model User {
  id                String   @id @default(uuid())
  org_id            String
  email             String
  name              String?
  role              UserRole @default(member)
  auth_provider_id  String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  @@index([org_id])
  @@index([auth_provider_id])
}

model Agent {
  id                      String       @id @default(uuid())
  org_id                  String
  agent_type              AgentType
  display_name            String
  status                  AgentStatus  @default(onboarding)
  personality_config      Json?
  context_snapshot        Json?        // what the agent "knows" about the business
  system_prompt_override  String?      @db.Text
  monthly_budget_cents    Int?         // e.g. 999 = $9.99/mo → dictates model + token limit
  token_usage_current_month Int        @default(0)
  token_usage_reset_at    DateTime?    // start of current billing month
  last_execution_at       DateTime?    // last proactive run (for scheduling)
  created_at              DateTime     @default(now())
  activated_at            DateTime?
  updated_at              DateTime     @updatedAt

  organization   Organization   @relation(fields: [org_id], references: [id], onDelete: Cascade)
  okrs           OKR[]
  tasks          Task[]
  agent_messages AgentMessage[]
  daily_reports  DailyReport[]
  events         Event[]
  agent_memories AgentMemory[]
  agent_files    AgentFile[]
  coordination_outbound CoordinationMessage[] @relation("CoordinationFrom")

  @@index([org_id])
  @@index([org_id, status])
}

model CoordinationMessage {
  id           String   @id @default(uuid())
  org_id       String
  from_agent_id String
  to_agent_ids String?  // JSON array of agent ids, or null = broadcast to all in org
  content      String   @db.Text
  intent       String?  // e.g. "working_on", "blocked", "completed"
  created_at   DateTime @default(now())

  from_agent Agent  @relation("CoordinationFrom", fields: [from_agent_id], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  @@index([org_id])
  @@index([from_agent_id])
  @@index([created_at])
}

model AgentMemory {
  id         String   @id @default(uuid())
  agent_id   String
  key        String   // namespace + key for lookups
  value      String   @db.Text
  updated_at DateTime @updatedAt

  agent Agent @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  @@unique([agent_id, key])
  @@index([agent_id])
}

model AgentFile {
  id         String   @id @default(uuid())
  agent_id   String
  org_id     String
  path       String   // relative path, sandboxed (no ..)
  content    String   @db.Text
  updated_at DateTime @updatedAt

  agent Agent @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  org   Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  @@unique([agent_id, path])
  @@index([agent_id])
  @@index([org_id])
}

model OKR {
  id                String        @id @default(uuid())
  agent_id          String
  org_id            String
  objective         String        @db.Text
  key_results       Json          // [{description, metric, target, current, unit}]
  status            OKRStatus     @default(proposed)
  agent_feedback    String?       @db.Text
  feasibility_score Float?
  time_horizon      TimeHorizon?
  due_date          DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  agent  Agent   @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([agent_id])
  @@index([org_id])
}

model Task {
  id            String       @id @default(uuid())
  agent_id      String
  okr_id        String?
  parent_task_id String?
  title         String
  description   String?      @db.Text
  status        TaskStatus   @default(planned)
  priority      TaskPriority @default(medium)
  output        Json?
  tools_used    String[]
  started_at    DateTime?
  completed_at  DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  agent        Agent  @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  okr         OKR?   @relation(fields: [okr_id], references: [id], onDelete: SetNull)
  parent_task Task?  @relation("TaskSubtasks", fields: [parent_task_id], references: [id], onDelete: SetNull)
  subtasks    Task[] @relation("TaskSubtasks")

  @@index([agent_id])
  @@index([okr_id])
  @@index([created_at])
}

model AgentMessage {
  id          String      @id @default(uuid())
  agent_id    String
  org_id      String
  role        MessageRole
  content     String      @db.Text
  message_type MessageType @default(question)
  metadata    Json?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  agent Agent @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  org   Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  @@index([agent_id])
  @@index([org_id])
  @@index([agent_id, created_at])
}

model DailyReport {
  id                 String   @id @default(uuid())
  agent_id           String
  org_id             String
  report_date        DateTime @db.Date
  summary            String   @db.Text
  okr_progress       Json?    // [{okr_id, progress_delta, notes}]
  tasks_completed    String[] // uuid[]
  tasks_in_progress  String[]
  blockers           Json?    // [{description, severity, needs_human}]
  recommendations   Json?    // proactive suggestions
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  agent Agent @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  org   Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  @@unique([agent_id, report_date])
  @@index([agent_id])
  @@index([org_id])
}

model ToolIntegration {
  id                   String                 @id @default(uuid())
  org_id               String
  tool_type            ToolType
  credentials_encrypted Bytes?
  config               Json?
  status               ToolIntegrationStatus  @default(connected)
  last_synced_at       DateTime?
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  @@index([org_id])
}

model Event {
  id         String   @id @default(uuid())
  org_id     String
  agent_id   String?
  event_type String   // agent.created | okr.proposed | task.completed | report.generated
  payload    Json?
  created_at DateTime @default(now())

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  agent        Agent?        @relation(fields: [agent_id], references: [id], onDelete: SetNull)
  @@index([org_id])
  @@index([agent_id])
  @@index([created_at])
}
